FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    left
    {
        type            symmetryPlane;
    }
    right
    {
        type            zeroGradient;
    }
    front
    {
        type            zeroGradient;
    }
    back
    {
        type            zeroGradient;
    }
    bottom_wall
    {
        type            zeroGradient;
    }
    top
    {
        type            zeroGradient;
    }
    nozzle_27mm_5mm_m
    {
        type            zeroGradient;
    }
    nozzle
    {
        type            zeroGradient;
    }
    vent_lower
    {
        type            calculated;//totalPressure;  //zeroGradient;
        value           $internalField;
    }
    vent_upper
    {
        type            calculated;  //totalPressure;  //zeroGradient;
        value           $internalField;
    }
}
