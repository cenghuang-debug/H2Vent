FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

actions
(
//create nozzle
    {
        name    nozzle;
        type    faceSet;
        action  new;
        source  patchToFace;
        sourceInfo
            {
                patch "bottom";
            }
    }
    {
        name    nozzle;
        type    faceSet;
        action  subset;
        source  cylinderToFace;
        sourceInfo
        {
            p1 (0 0 -1e-3);  // center of circle (bottom)
            p2 (0 0 1e-3);  // center of circle (top)
            radius 13.5e-3; // radius of the circle
        }
    }
//create bottom_wall
    {
        name    bottom_wall;
        type    faceSet;
        action  new;
        source  patchToFace;
        sourceInfo
            {
                patch "bottom";
            }
    }
    {
        name    bottom_wall;
        type    faceSet;
        action  subtract;
        source  faceToFace;
        set     nozzle;
    }
