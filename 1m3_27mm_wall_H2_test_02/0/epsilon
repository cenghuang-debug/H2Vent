FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 2.76e-06;

boundaryField
{
    left
    {
        type            symmetryPlane;
    }
    right
    {
        type            inletOutlet;
        inletValue      uniform 2.76e-06;
        value           uniform 2.76e-06;
    }
    top
    {
        type            inletOutlet;
        inletValue      uniform 2.76e-06;
        value           uniform 2.76e-06;
    }
    front
    {
        type            inletOutlet;
        inletValue      uniform 2.76e-06;
        value           uniform 2.76e-06;
    }
    back
    {
        type            inletOutlet;
        inletValue      uniform 2.76e-06;
        value           uniform 2.76e-06;
    }
    nozzle_27mm_5mm_m
    {
        type            epsilonWallFunction;
        value           uniform 2.76e-06;
    }
    box_shell_m
    {
        type            epsilonWallFunction;
        value           uniform 2.76e-06;
    }
    nozzle
    {
        type            turbulentMixingLengthDissipationRateInlet;
        mixingLength    0.00103;
        phi             phi;
        k               k;
        value           uniform 77.13;
    }
    bottom_wall
    {
        type            epsilonWallFunction;
        value           uniform 2.76e-06;
    }
}


