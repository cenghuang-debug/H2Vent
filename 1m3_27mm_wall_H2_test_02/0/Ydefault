FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      Ydefault;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    left
    {
        type            symmetryPlane;
    }
    right
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }
    top
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }
    front
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }
    back
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }
    nozzle_27mm_5mm_m
    {
        type            zeroGradient;
    }
    box_shell_m
    {
        type            zeroGradient;
    }
    nozzle
    {
        type            fixedValue;
        value           uniform 0;
    }
    bottom_wall
    {
        type            zeroGradient;
    }
}


